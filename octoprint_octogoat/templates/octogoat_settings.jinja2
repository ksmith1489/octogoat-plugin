<div class="section">
  <h3>OctoGoat</h3>

  <div class="control-group">
    <label class="control-label" for="octogoat_api_key">Lazarus API Key</label>
    <div class="controls">
      <input id="octogoat_api_key"
             type="text"
             class="input-block-level"
             placeholder="Paste your Render/Lazarus API key"
             data-bind="value: settings.plugins.octogoat.api_key" />
      <p class="help-block">
        This is sent as: Authorization: Bearer &lt;key&gt; to /api/ping
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label" for="octogoat_engine_url">Engine URL</label>
    <div class="controls">
      <input id="octogoat_engine_url"
             type="text"
             class="input-block-level"
             data-bind="value: settings.plugins.octogoat.engine_url" />
      <p class="help-block">
        Example: https://app.lazarus3dprint.com
      </p>
    </div>
  </div>

  <div class="control-group">
    <div class="controls">
      <label class="checkbox">
        <input type="checkbox" data-bind="checked: confirmed" />
        I confirm I’m testing safely (nozzle clear, temps OK).
      </label>
    </div>
  </div>

  <div class="control-group">
    <div class="controls">
      <button class="btn btn-primary"
              data-bind="click: testConnection, enable: confirmed">
        Test Connection
      </button>
    </div>
  </div>
</div>