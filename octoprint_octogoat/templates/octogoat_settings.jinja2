<div id="settings_plugin_octogoat" data-bind="with: settings.plugins.octogoat">
	<div class="section">
		<h3>OctoGoat Settings</h3>

		<div class="control-group">
			<label class="control-label">Engine URL</label>
			<div class="controls">
				<input type="text"
					   class="input-block-level"
					   data-bind="value: settings.plugins.octogoat.engine_url">
			</div>
		</div>

		<div class="control-group">
			<label class="control-label">API Key</label>
			<div class="controls">
				<input type="text"
					   class="input-block-level"
					   data-bind="value: settings.plugins.octogoat.api_key">
			</div>
		</div>
	</div>
		<div class="control-group">
			<div class="controls">
				<button class="btn btn-primary"
						data-bind="click: $root.testConnection">
					Test Connection
				</button>
			</div>
	</div>
</div>	