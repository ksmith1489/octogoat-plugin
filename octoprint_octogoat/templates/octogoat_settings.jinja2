<form class="form-horizontal">
    <h3>OctoGoat</h3>

    <div class="control-group">
        <label class="control-label" for="settings-octogoat-api">
            API Key
        </label>
        <div class="controls">
            <input id="settings-octogoat-api"
                   type="text"
                   class="input-block-level"
                   data-bind="value: settings.plugins.octoprint_octogoat.api_key" />
        </div>
    </div>

    <div class="control-group">
        <label class="control-label" for="settings-octogoat-url">
            Engine URL
        </label>
        <div class="controls">
            <input id="settings-octogoat-url"
                   type="text"
                   class="input-block-level"
                   data-bind="value: settings.plugins.octoprint_octogoat.engine_url" />
        </div>
    </div>

    <div class="control-group">
        <div class="controls">
            <button type="button"
                    class="btn btn-primary"
                    data-bind="click: testOctoGoatConnection">
                Test Connection
            </button>
        </div>
    </div>
</form>
