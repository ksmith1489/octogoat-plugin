<div id="tab_plugin_octogoat" class="tab-pane">
    <div class="container-fluid octogoat-ui">

        <div class="octogoat-hero">
            <div class="octogoat-title-wrap">
                <div class="octogoat-title-logo">
                    <img class="octogoat-goat-overlay"
                         src="/plugin/octogoat/static/img/octogoat_icon.svg"
                         alt="OctoGOAT">
                    <h2 class="octogoat-title">OctoGOAT</h2>
                </div>

                <div class="octogoat-tagline">
                    Save time. Save money. Save that print.
                </div>
            </div>
        </div>

        <div class="octogoat-nav-row">
            <div class="octogoat-nav-left">
                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#pricing-modal"
                        Pricing
                </button>

                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#howto-modal"
                        title="this is a test to see if the text will show up as a tooltip"">
                    How To
                </button>

                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#contact-modal"
                        title="questions, concerns, anything else contact ksmith14892protonmail.com">
                    Contact
                </button>
            </div>

            <div class="octogoat-nav-right">
                <span class="label label-success"
                      data-bind="visible: licenseValid()">
                    License Valid
                </span>

                <span class="label label-important"
                      data-bind="visible: !licenseValid()">
                    License Required
                </span>
            </div>
        </div>

        <div class="octogoat-card">
            <h4>Inputs</h4>

            <div class="row-fluid">
                <div class="span4">
                    <label>Measured Print Height (mm)</label>

                    <input type="number"
                            step="0.1"
                            class="input-block-level octogoat-input"
                            placeholder="22.0"
                            data-bind="value: measuredHeight"
                            title="measure the height of partial print from extreme left and right
                                record the lowest of the two measurements here to the nearest 0,1mm">
                </div>

                <div class="span4">
                    <label>Measured side used choose: left/right</label>

                    <select class="input-block-level octogoat-input"
                            data-bind="value: x-extreme"
                            title="choose the same side which produced lowest measurement">
                        <option value="Left</option>
                        <option value="Right"></option>
                    </select>
                </div>

                <div class="span4">
                    <label>Layer Height (mm)</label>

                    <input type="number"
                           step="0.01"
                           class="input-block-level octogoat-input"
                           placeholder="0.2"
                           data-bind="value: layerHeight"
                           title="Enter the layerheight from slicer settings*
                           if an different initial layer height is used, take the 
                           difference between the two layer heights and subtract 
                           from measured print height input">
                </div>
            </div>

            <button class="btn btn-large btn-block octogoat-action-btn"
                    data-bind="click: buildResume, enable: licenseValid()"
                    title="reconstructs safe resume gcode based on inputs provided">
                RECONSTRUCT GCODE AND PROCEED TO CALIBRATE POSITION
            </button>
        </div>

        <div class="octogoat-card" data-bind="visible: resumeBuilt()">
            <h4>CALIBRATE MY POSITION</h4>

            <div class="octogoat-warning-box">
                *Warning! While possible to resume a failed print in seconds by simply clicking
                "Set Assumed Position" and skipping to Resume Now, it is not recommended!
                <br><br>
                Is it awesome? Yes, but a safe and precise resume only takes a couple more minutes.
                <br><br>
                If something doesn't look right you can always cut power and try again.
                <br><br>
                If the print is still on the bed, with OctoGoat it's not dead.
                <br><br>
                Be safe! Be kind! And know you are appreciated.
                <br><br>
                OctoGoat powered by Lazarus. Patent pending. All rights reserved.
            </div>

            <div class="row-fluid">
                <div class="span4">
                    <button class="btn btn-block octogoat-function-btn"
                            data-bind="click: applyPark"
                            title="PLACEHOLDER TOOLTIP">
                        1 — ASSUMED POSITION
                    </button>
                </div>

                <div class="span4">
                    <button class="btn btn-block octogoat-function-btn"
                            data-bind="click: goToDatum"
                            title="PLACEHOLDER TOOLTIP">
                        2 — MOVING ON TO PERFECTION
                    </button>
                </div>

                <div class="span4">
                    <button class="btn btn-block octogoat-function-btn"
                            data-bind="click: lockDatum"
                            title="PLACEHOLDER TOOLTIP">
                        3 — POSITION CALIBRATION COMPLETE
                    </button>
                </div>
            </div>
        </div>

        <div class="octogoat-card">
            <h4>Resume GCode Preview</h4>

            <pre class="octogoat-preview"
                 data-bind="visible: resumeBuilt(), text: previewText"></pre>
        </div>

        <div class="octogoat-card octogoat-resume-card">
            <label class="checkbox octogoat-checkbox">
                <input type="checkbox"
                       data-bind="checked: motionAcknowledged">

                I acknowledge toolhead has been aligned, nozzle temp is correct and it is safe to move
            </label>

            <button class="btn btn-large octogoat-resume-btn"
                    data-bind="enable: motionAcknowledged() && resumeBuilt(), click: resumeNow"
                    title="PLACEHOLDER TOOLTIP">
                RESUME PRINT
            </button>
        </div>
    </div>

    <!-- Pricing Modal -->
    <div id="pricing-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="pricing-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="pricing-modal-label">Activate OctoGOAT</h3>
        </div>

        <div class="modal-body">
            <p>Choose a plan to activate OctoGOAT.</p>
            <div id="pricing-table-container"></div>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>

    <!-- How To Modal -->
    <div id="howto-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="howto-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="howto-modal-label">How To</h3>
        </div>

        <div class="modal-body">
            <p>PLACEHOLDER HOW-TO CONTENT</p>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>

    <!-- Contact Modal -->
    <div id="contact-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="contact-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="contact-modal-label">Contact</h3>
        </div>

        <div class="modal-body">
            <p>PLACEHOLDER CONTACT CONTENT</p>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>
</div>