<div id="tab_plugin_octogoat" class="tab-pane">
    <div class="container-fluid octogoat-ui">

        <div class="octogoat-hero">
            <img class="octogoat-hero-art"
                 src="/plugin/octogoat/static/img/octogoat_hero.svg"
                 alt="OctoGOAT hero art">
        </div>

        <div class="octogoat-nav-row">
            <div class="octogoat-nav-left">
                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#pricing-modal"
                        title="place holder">
                    Pricing/Plans
                </button>

                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#assumed-position-modal"
                        title="place holder">
                    Assumed Position
                </button>

                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#howto-modal"
                        title="place holder">
                    How To
                </button>

                <button class="btn octogoat-nav-btn"
                        type="button"
                        data-toggle="modal"
                        data-target="#contact-modal"
                        title="place holder">
                    Contact
                </button>
            </div>

            <div class="octogoat-nav-right">
                <span class="label label-success"
                      data-bind="visible: licenseValid()">
                    License Valid
                </span>

                <span class="label label-important"
                      data-bind="visible: !licenseValid()">
                    License Required
                </span>
            </div>
        </div>

        <div class="octogoat-card">
            <div class="octogoat-inputs-head">
                <h4>Inputs</h4>

                <div class="octogoat-file-selector">
                    <div class="octogoat-file-selector-label">Selected GCODE File</div>

                    <div class="octogoat-file-selected"
                         data-bind="text: selectedFileLabel"
                         title="place holder"></div>

                    <div class="octogoat-file-selector-controls">
                        <select class="input-block-level octogoat-input"
                                data-bind="
                                    options: availableFiles,
                                    optionsText: 'label',
                                    optionsValue: 'path',
                                    value: selectedServerFilePath,
                                    optionsCaption: 'Choose OctoPrint file',
                                    event: { change: selectServerFile }
                                "
                                title="place holder"></select>

                        <button class="btn octogoat-function-btn octogoat-file-picker-btn"
                                type="button"
                                data-bind="click: openLocalFilePicker"
                                title="place holder">
                            Choose From Device
                        </button>
                    </div>

                    <div class="octogoat-file-dropzone"
                         data-bind="css: { 'is-dragging': isDraggingFile() }"
                         title="place holder">
                        Drag and drop a `.gcode` file here
                    </div>

                    <input id="octogoat-local-file-input"
                           type="file"
                           accept=".gcode,.gco,.gc,.g"
                           class="octogoat-hidden-file-input">
                </div>
            </div>

            <div class="row-fluid">
                <div class="span6">
                    <label>Measured Print Height (mm)</label>

                    <input type="number"
                           step="0.1"
                           class="input-block-level octogoat-input"
                           placeholder="22.0"
                           data-bind="value: measuredHeight"
                           title="Measure the partial print from both sides and enter the lower value to the nearest 0.1 mm.">
                </div>

                <div class="span6">
                    <label>Alignment Side</label>

                    <select class="input-block-level octogoat-input"
                            data-bind="value: alignmentSide"
                            title="Choose the side used for the left or right alignment datum selection rule.">
                        <option value="left">Left</option>
                        <option value="right">Right</option>
                    </select>
                </div>
            </div>

            <div class="octogoat-help-text">
                Layer height is detected automatically from the selected GCODE file.
            </div>

            <button class="btn btn-large btn-block octogoat-action-btn"
                    data-bind="click: buildResume, enable: licenseValid()"
                    title="Reconstruct safe resume GCODE using the selected file and measured height.">
                RECONSTRUCT GCODE AND PROCEED TO CALIBRATE POSITION
            </button>
        </div>

        <div class="octogoat-card" data-bind="visible: resumeBuilt()">
            <div class="octogoat-stage-header">
                <h4>Calibrate Position</h4>

                <div class="octogoat-datum-display"
                     title="place holder">
                    Datum / True Alignment Point:
                    <span>X=<strong data-bind="text: datumX"></strong></span>
                    <span>Y=<strong data-bind="text: datumY"></strong></span>
                    <span>Z=<strong data-bind="text: datumZ"></strong></span>
                </div>
            </div>

            <div class="octogoat-warning-box">
                *Warning! While possible to resume a failed print in seconds by simply clicking
                "Set Assumed Position" and skipping to Resume Now, it is not recommended!
                <br><br>
                Is it awesome? Yes, but a safe and precise resume only takes a couple more minutes.
                <br><br>
                If something doesn't look right you can always cut power and try again.
                <br><br>
                If the print is still on the bed, with OctoGoat it's not dead.
                <br><br>
                Be safe! Be kind! And know you are appreciated.
                <br><br>
                OctoGoat powered by Lazarus. Patent pending. All rights reserved.
            </div>

            <div class="row-fluid">
                <div class="span4">
                    <button class="btn btn-block octogoat-function-btn"
                            data-bind="click: applyPark"
                            title="place holder">
                        1 - Assumed Position
                    </button>
                </div>

                <div class="span4">
                    <button class="btn btn-block octogoat-function-btn"
                            data-bind="click: goToDatum"
                            title="place holder">
                        2 - Moving On To Perfection
                    </button>
                </div>

                <div class="span4">
                    <button class="btn btn-block octogoat-function-btn"
                            data-bind="click: lockDatum"
                            title="place holder">
                        3 - True Alignment Complete
                    </button>
                </div>
            </div>
        </div>

        <div class="octogoat-card" data-bind="visible: resumeBuilt()">
            <h4>Resume GCODE Preview</h4>

            <pre class="octogoat-preview"
                 data-bind="visible: resumeBuilt(), text: previewText"></pre>
        </div>

        <div class="octogoat-card octogoat-resume-card">
            <label class="checkbox octogoat-checkbox">
                <input type="checkbox"
                       data-bind="checked: motionAcknowledged">

                I acknowledge toolhead has been aligned, nozzle temp is correct and it is safe to move
            </label>

            <div class="octogoat-resume-actions">
                <button class="btn btn-large octogoat-download-btn"
                        data-bind="enable: canDownloadResume(), click: downloadResume"
                        title="place holder">
                    Download Resume GCODE
                </button>

                <button class="btn btn-large octogoat-resume-btn"
                        data-bind="enable: canResume(), click: resumeNow"
                        title="place holder">
                    Resume Print
                </button>
            </div>
        </div>
    </div>

    <div id="pricing-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="pricing-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="pricing-modal-label">Activate OctoGOAT</h3>
        </div>

        <div class="modal-body">
            <p>Choose a plan to activate OctoGOAT.</p>
            <div id="pricing-table-container"></div>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>

    <div id="assumed-position-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="assumed-position-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="assumed-position-modal-label">Assumed Position</h3>
        </div>

        <div class="modal-body">
            <p class="octogoat-help-text">place holder</p>

            <div class="row-fluid">
                <div class="span4">
                    <label>X =</label>
                    <input type="number"
                           step="0.01"
                           class="input-block-level octogoat-input"
                           data-bind="value: parkX, event: { change: saveAssumedPosition }"
                           title="place holder">
                </div>

                <div class="span4">
                    <label>Y =</label>
                    <input type="number"
                           step="0.01"
                           class="input-block-level octogoat-input"
                           data-bind="value: parkY, event: { change: saveAssumedPosition }"
                           title="place holder">
                </div>

                <div class="span4">
                    <label>Z =</label>
                    <input type="number"
                           step="0.01"
                           class="input-block-level octogoat-input"
                           data-bind="value: parkZ, event: { change: saveAssumedPosition }"
                           title="place holder">
                </div>
            </div>

            <div class="octogoat-help-text">
                These values mirror the OctoGOAT park commands in OctoPrint's
                <strong>after print job completes</strong> and
                <strong>after print job is canceled</strong> GCODE scripts. Changes here update those scripts,
                and manual script edits are reloaded back into this display after save.
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>

    <div id="howto-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="howto-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="howto-modal-label">How To</h3>
        </div>

        <div class="modal-body">
            <p>PLACEHOLDER HOW-TO CONTENT</p>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>

    <div id="contact-modal"
         class="modal hide fade"
         tabindex="-1"
         role="dialog"
         aria-labelledby="contact-modal-label"
         aria-hidden="true">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h3 id="contact-modal-label">Contact</h3>
        </div>

        <div class="modal-body">
            <p>PLACEHOLDER CONTACT CONTENT</p>
        </div>

        <div class="modal-footer">
            <button class="btn" type="button" data-dismiss="modal">Close</button>
        </div>
    </div>
</div>
