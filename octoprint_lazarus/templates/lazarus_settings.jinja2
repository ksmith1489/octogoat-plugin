<form class="form-horizontal lazarus-settings-form">
  <h3>Lazarus Settings</h3>
  <p class="lazarus-settings-intro">
    Configure printer behavior, licensing, and optional Moonraker connectivity for Lazarus.
  </p>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_firmware_type">Firmware Type</label>
    <div class="controls">
      <select id="settings_plugin_lazarus_firmware_type"
              data-bind="value: settings.plugins.lazarus.firmware_type">
        <option value="klipper">Klipper</option>
        <option value="marlin">Marlin</option>
      </select>
      <p class="help-block">
        Select the firmware running on this printer.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_engine_url">License Service URL</label>
    <div class="controls">
      <input id="settings_plugin_lazarus_engine_url"
             type="text"
             class="input-block-level"
             data-bind="value: settings.plugins.lazarus.engine_url">
      <p class="help-block">
        Endpoint used for activation and license validation.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Saved Assumed Position</label>
    <div class="controls">
      <div class="row-fluid lazarus-axis-row">
        <div class="span4">
          <label class="lazarus-axis-label" for="settings_plugin_lazarus_park_x">X</label>
          <input id="settings_plugin_lazarus_park_x"
                 type="number"
                 step="0.01"
                 class="input-block-level"
                 data-bind="value: settings.plugins.lazarus.park_x">
        </div>

        <div class="span4">
          <label class="lazarus-axis-label" for="settings_plugin_lazarus_park_y">Y</label>
          <input id="settings_plugin_lazarus_park_y"
                 type="number"
                 step="0.01"
                 class="input-block-level"
                 data-bind="value: settings.plugins.lazarus.park_y">
        </div>

        <div class="span4">
          <label class="lazarus-axis-label" for="settings_plugin_lazarus_park_z">Z</label>
          <input id="settings_plugin_lazarus_park_z"
                 type="number"
                 step="0.01"
                 class="input-block-level"
                 data-bind="value: settings.plugins.lazarus.park_z">
        </div>
      </div>

      <p class="help-block">
        Optional starting coordinates for printers that park in a known location after a failed job or cancel event.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_safe_z_hop">Safe Z Hop (mm)</label>
    <div class="controls">
      <input id="settings_plugin_lazarus_safe_z_hop"
             type="number"
             min="0"
             step="0.01"
             class="input-block-level"
             data-bind="value: settings.plugins.lazarus.safe_z_hop">
      <p class="help-block">
        Extra clearance added after Position Calibrated locks the alignment point.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_z_max_override_mm">Advanced Z Max Override (mm)</label>
    <div class="controls">
      <input id="settings_plugin_lazarus_z_max_override_mm"
             type="number"
             min="0"
             step="0.01"
             class="input-block-level"
             data-bind="value: settings.plugins.lazarus.z_max_override_mm">
      <p class="help-block">
        Optional fallback if Lazarus cannot detect your machine's Z maximum from Moonraker or the OctoPrint printer profile.
      </p>
    </div>
  </div>

  <hr>

  <h3>Moonraker / Klipper Mode</h3>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_moonraker_url">Moonraker URL</label>
    <div class="controls">
      <input id="settings_plugin_lazarus_moonraker_url"
             type="text"
             class="input-block-level"
             placeholder="http://printer.local:7125"
             data-bind="value: settings.plugins.lazarus.moonraker_url">
      <p class="help-block">
        Base URL for Moonraker. Toggle Moonraker mode from the Lazarus tab.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_moonraker_api_key">Moonraker API Key</label>
    <div class="controls">
      <input id="settings_plugin_lazarus_moonraker_api_key"
             type="password"
             class="input-block-level"
             data-bind="value: settings.plugins.lazarus.moonraker_api_key">
      <p class="help-block">
        Leave blank unless your Moonraker instance requires an API key.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Moonraker Assumed Position</label>
    <div class="controls">
      <div class="row-fluid lazarus-axis-row">
        <div class="span4">
          <label class="lazarus-axis-label" for="settings_plugin_lazarus_moonraker_park_x">X</label>
          <input id="settings_plugin_lazarus_moonraker_park_x"
                 type="number"
                 step="0.01"
                 class="input-block-level"
                 data-bind="value: settings.plugins.lazarus.moonraker_park_x">
        </div>

        <div class="span4">
          <label class="lazarus-axis-label" for="settings_plugin_lazarus_moonraker_park_y">Y</label>
          <input id="settings_plugin_lazarus_moonraker_park_y"
                 type="number"
                 step="0.01"
                 class="input-block-level"
                 data-bind="value: settings.plugins.lazarus.moonraker_park_y">
        </div>

        <div class="span4">
          <label class="lazarus-axis-label" for="settings_plugin_lazarus_moonraker_park_z">Z</label>
          <input id="settings_plugin_lazarus_moonraker_park_z"
                 type="number"
                 step="0.01"
                 class="input-block-level"
                 data-bind="value: settings.plugins.lazarus.moonraker_park_z">
        </div>
      </div>

      <p class="help-block">
        Optional starting coordinates for Moonraker mode when your printer parks in a known location.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Moonraker Upload Behavior</label>
    <div class="controls">
      <label class="checkbox">
        <input type="checkbox"
               data-bind="checked: settings.plugins.lazarus.moonraker_upload_and_print">
        Start the uploaded resume file automatically when Resume Print is pressed
      </label>
      <p class="help-block">
        If unchecked, Resume Print uploads the generated file to Moonraker without starting it.
      </p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label" for="settings_plugin_lazarus_moonraker_timeout_seconds">Moonraker Timeout (seconds)</label>
    <div class="controls">
      <input id="settings_plugin_lazarus_moonraker_timeout_seconds"
             type="number"
             min="1"
             step="1"
             class="input-block-level"
             data-bind="value: settings.plugins.lazarus.moonraker_timeout_seconds">
    </div>
  </div>
</form>
